#!/usr/bin/env bash
set -euo pipefail

# Resolve script dir (handles invocation from PATH where BASH_SOURCE may be just the command name)
script_path="${BASH_SOURCE[0]}"
[[ "$script_path" == */* ]] || script_path=$(command -v "$script_path")
SCRIPT_DIR=$(cd "$(dirname "$script_path")" && pwd)
USER_CONFIG="${XDG_CONFIG_HOME:-$HOME/.config}/git-tools/ai-config"
# Prefer user config; fall back to bundled config next to the script
if [[ -f "$USER_CONFIG" ]]; then
  AI_CONFIG="$USER_CONFIG"
else
  AI_CONFIG="$SCRIPT_DIR/ai-config"
fi

# Parse config file. Outputs lines: name|email|default_model|models_csv
read_ai_config() {
  [[ -f "$AI_CONFIG" ]] || return 0
  while IFS= read -r line || [[ -n "$line" ]]; do
    line=$(echo "$line" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
    [[ -z "$line" || "$line" == \#* ]] && continue
    echo "$line"
  done < "$AI_CONFIG"
}

# Read last-used AI and model from log (sets last_ai_name, last_model)
read_last_used() {
  local log_file="${XDG_CONFIG_HOME:-$HOME/.config}/git-tools/commit-ai-coauthor.log"
  [[ -f "$log_file" ]] || return 0
  local line
  line=$(tail -n1 "$log_file" 2>/dev/null) || return 0
  IFS=$'\t' read -r _ last_ai_name last_model _ <<< "$line"
}

# Append commit to log (timestamp, ai_name, model, commit_hash)
append_log() {
  local log_file="${XDG_CONFIG_HOME:-$HOME/.config}/git-tools/commit-ai-coauthor.log"
  mkdir -p "$(dirname "$log_file")"
  printf '%s\t%s\t%s\t%s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$name" "$model" "$(git rev-parse HEAD)" >> "$log_file"
}

# Get email and default_model for an AI by name (from config)
get_ai_info() {
  local name="$1"
  while IFS='|' read -r n email default_model _; do
    [[ "$n" == "$name" ]] && printf '%s\t%s\n' "$email" "$default_model" && return 0
  done < <(read_ai_config)
}

# Get models list for an AI (4th field from config, comma->newline)
get_models_for_ai() {
  local name="$1"
  local default_model="$2"
  local models
  models=$(read_ai_config | while IFS='|' read -r n _ _ m; do
    [[ "$n" == "$name" ]] && echo "$m" && break
  done)
  if [[ -n "$models" ]]; then
    echo "$models" | tr ',' '\n' | grep -v '^$'
  else
    [[ -n "$default_model" ]] && echo "$default_model"
  fi
}

# Print usage and exit
show_help() {
  cat <<'EOF'
commit-ai-coauthor - Interactive commit helper that appends AI co-authorship trailers

USAGE
  commit-ai-coauthor [OPTIONS]
  git ac [OPTIONS]

OPTIONS
  -m "message"    Use the given commit message (skips editor). Same as git commit -m.
  --contrib N     LLM contribution percentage (e.g. 50, 75%, 100). Skips the prompt.
  --last-used     Skip AI and model selection; use the last-used AI co-author and model.
                  Combined with -m, makes the command fully non-interactive.
  --help          Show this help and exit.

  All other arguments are passed through to git commit (e.g. --amend, --no-verify, -v).

EXAMPLES
  commit-ai-coauthor                    # Interactive: select AI, model, enter message
  commit-ai-coauthor -m "fix: typo"      # Interactive: select AI and model, message from -m
  commit-ai-coauthor -m "fix: typo" --last-used   # Non-interactive: commit with last-used AI
  commit-ai-coauthor -m "fix: typo" --contrib 100   # Skip contribution prompt, use 100%

EOF
}

# Parse -m "message", --help, --last-used, --contrib from args; collect rest for git commit
commit_message=""
last_used=false
contrib_arg=""
git_commit_args=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    -m)
      if [[ $# -gt 1 ]]; then
        commit_message="$2"
        shift 2
      else
        echo "Error: -m requires a message" >&2
        exit 1
      fi
      ;;
    --contrib|-c)
      if [[ $# -gt 1 ]]; then
        contrib_arg="$2"
        shift 2
      else
        echo "Error: --contrib requires a value" >&2
        exit 1
      fi
      ;;
    --help|-h)
      show_help
      exit 0
      ;;
    --last-used)
      last_used=true
      shift
      ;;
    *)
      git_commit_args+=("$1")
      shift
      ;;
  esac
done

# Check for staged changes (same behavior as git commit: exit if nothing staged)
staged=$(git diff --cached --name-only 2>/dev/null | head -1)
if [[ -z "$staged" ]]; then
  echo "no changes added to commit" >&2
  exit 1
fi

last_ai_name=""
last_model=""
read_last_used

# --last-used: skip all interactivity, use last-used AI and model
if [[ "$last_used" == true ]]; then
  if [[ -z "$last_ai_name" || -z "$last_model" ]]; then
    echo "No previous AI co-author found. Run without --last-used first." >&2
    exit 1
  fi
  ai_info=$(get_ai_info "$last_ai_name")
  if [[ -z "$ai_info" ]]; then
    echo "AI '$last_ai_name' not found in config." >&2
    exit 1
  fi
  name="$last_ai_name"
  email=$(echo "$ai_info" | cut -f1)
  model="$last_model"
  if [[ -n "$contrib_arg" ]]; then
    contrib="$contrib_arg"
    [[ "$contrib" =~ ^[0-9]+$ ]] && contrib="${contrib}%"
  else
    contrib="50%"
  fi
else
  # No TTY: commit without AI attribution
  if [[ ! -t 0 ]] || [[ ! -c /dev/tty ]]; then
    if [[ -n "$commit_message" ]]; then
      ((${#git_commit_args[@]})) && git commit -m "$commit_message" "${git_commit_args[@]}" || git commit -m "$commit_message"
    else
      ((${#git_commit_args[@]})) && git commit "${git_commit_args[@]}" || git commit
    fi
    exit 0
  fi

  # Build AI list for fzf: "DisplayName <email>" for display, tab-separated with name|email|model for parsing
  build_ai_list() {
    printf '%s\t%s\t%s\n' "None" "" ""
    read_ai_config | while IFS='|' read -r name email default_model _; do
      printf '%s <%s>\t%s\t%s\t%s\n' "$name" "$email" "$name" "$email" "$default_model"
    done
  }

  # fzf: Select AI co-author
  fzf_ai_args=(--no-sort --delimiter=$'\t' --with-nth=1 --header='Select AI co-author' --height=~10)
  [[ -n "$last_ai_name" ]] && fzf_ai_args+=(--query "$last_ai_name")
  selection=$(build_ai_list | fzf "${fzf_ai_args[@]}" 2>/dev/null)

  if [[ -z "$selection" ]]; then
    echo "Aborted." >&2
    exit 1
  fi

  # Parse selection: display_name\tname\temail\tmodel
  name=$(echo "$selection" | cut -f2)
  email=$(echo "$selection" | cut -f3)
  default_model=$(echo "$selection" | cut -f4)

  # No AI selected
  if [[ "$name" == "None" ]] || [[ -z "$email" ]]; then
    if [[ -n "$commit_message" ]]; then
      ((${#git_commit_args[@]})) && git commit -m "$commit_message" "${git_commit_args[@]}" || git commit -m "$commit_message"
    else
      ((${#git_commit_args[@]})) && git commit "${git_commit_args[@]}" || git commit
    fi
    exit 0
  fi

  # AI selected: fzf for model (filtered by co-author) with option to type custom
  model_list=$(get_models_for_ai "$name" "$default_model")
  model_options=$(
    printf 'Other (type custom)\n'
    printf '%s\n' "$model_list" | grep -v '^$'
  )

  fzf_model_args=(--no-sort --print-query --header="Model for $name (select or type custom)" --height=~10)
  [[ -n "$last_model" ]] && [[ "$last_ai_name" == "$name" ]] && fzf_model_args+=(--query "$last_model")
  model=$(
    echo "$model_options" | fzf "${fzf_model_args[@]}" 2>/dev/null | {
      read -r query
      read -r chosen || true
      # If they selected "Other (type custom)", prompt for input
      if [[ "$chosen" == "Other (type custom)" ]]; then
        read -p "Model: " -r custom < /dev/tty
        echo "${custom:-}"
      elif [[ -n "$chosen" ]]; then
        echo "$chosen"
      else
        # They typed something and hit enter with no selection - use query as custom
        echo "$query"
      fi
    }
  )

  # If model still empty, use default
  [[ -z "$model" ]] && model="$default_model"

  if [[ -n "$contrib_arg" ]]; then
    contrib="$contrib_arg"
    [[ "$contrib" =~ ^[0-9]+$ ]] && contrib="${contrib}%"
  else
    contrib="50%"
    read -p "LLM contribution [50%]: " -r contrib_input < /dev/tty
    if [[ -n "$contrib_input" ]]; then
      contrib="$contrib_input"
      [[ "$contrib" =~ ^[0-9]+$ ]] && contrib="${contrib}%"
    fi
  fi
fi

# Get commit message
msg_file=$(mktemp)
trap 'rm -f "$msg_file"' EXIT

if [[ -n "$commit_message" ]]; then
  printf '%s\n' "$commit_message" > "$msg_file"
else
  # Open editor with template
  {
    echo "# Enter commit message. Lines starting with # will be ignored."
    echo "#"
  } > "$msg_file"
  ${EDITOR:-vim} "$msg_file"
  # Strip comment lines (portable)
  sed '/^#/d' "$msg_file" > "${msg_file}.tmp" && mv "${msg_file}.tmp" "$msg_file"
fi

# Validate non-empty message
if ! grep -q . "$msg_file"; then
  echo "Error: Empty commit message" >&2
  exit 1
fi

# Add trailers via git interpret-trailers
trailer_file=$(mktemp)
trap 'rm -f "$msg_file" "$trailer_file"' EXIT

trailer_args=(--trailer "Co-authored-by: $name <$email>")
[[ -n "$model" ]] && trailer_args+=(--trailer "Assistant-model: $model")
trailer_args+=(--trailer "LLM-Contrib: $contrib")

# Ensure blank line before trailers (required by git)
echo "" >> "$msg_file"
git interpret-trailers "${trailer_args[@]}" "$msg_file" > "$trailer_file"
mv "$trailer_file" "$msg_file"

if ((${#git_commit_args[@]})); then
  git commit "${git_commit_args[@]}" -F "$msg_file"
else
  git commit -F "$msg_file"
fi
append_log
